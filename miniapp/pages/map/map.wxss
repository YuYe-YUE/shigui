/* 全屏地图 */
.full-map { width: 100%; height: 100vh; }

/* 底部弹出卡片 (Bottom Sheet 风格) */
.popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--white);
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.08);
  z-index: 1000;
  animation: slideUp 0.3s ease-out;
}

/* 顶部指示条 */
.popup::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.popup-title { 
  font-size: 34rpx; 
  font-weight: 700; 
  color: var(--text-main); 
  flex: 1;
  margin-right: 20rpx;
}
.popup-type { 
  font-size: 22rpx; 
  padding: 6rpx 16rpx; 
  border-radius: 20rpx; 
  font-weight: 600; 
}
.type-lost { background: var(--lost-light); color: var(--lost-color); }
.type-found { background: var(--found-light); color: var(--found-color); }

.popup-meta { 
  font-size: 28rpx; 
  color: var(--text-second); 
  margin-bottom: 30rpx; 
  line-height: 1.5;
}

.popup-action {
  font-size: 28rpx;
  color: var(--primary-color);
  text-align: center;
  padding: 24rpx 0;
  font-weight: 600;
  border: 2rpx solid var(--primary-color);
  border-radius: 40rpx;
  transition: all 0.2s;
}
.popup-action:active {
  background: var(--primary-light);
}
