.post-card {
  background: var(--white, #ffffff);
  border-radius: var(--border-radius, 16rpx);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow, 0 4rpx 12rpx rgba(0, 0, 0, 0.05));
  overflow: hidden;
  break-inside: avoid; /* 瀑布流防截断 */
  transform: translateZ(0); /* 修复某些机型的圆角与渲染 bug */
}

/* 按压态统一定义在页面层级的 component 上或者如果需要可以开启 hover-class */

.image-placeholder {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-icon {
  font-size: 64rpx;
  opacity: 0.3;
}

.content {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.header {
  display: flex;
  align-items: flex-start;
}

.post-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  margin-right: 12rpx;
  white-space: nowrap;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.type-lost {
  background: var(--lost-light, #FFF3E0);
  color: var(--lost-color, #FF9800);
}

.type-found {
  background: var(--found-light, #E8F5E9);
  color: var(--found-color, #4CAF50);
}

.post-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #1A1A1A);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.location {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--text-second, #666666);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.time {
  font-size: 22rpx;
  color: var(--text-light, #999999);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}