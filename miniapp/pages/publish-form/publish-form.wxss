.container { padding: 14px; }

.form-group { margin-bottom: 16px; }
.form-label { font-size: 14px; font-weight: 600; margin-bottom: 6px; color: #333; }
.required { color: #e74c3c; }

.form-input {
  background: #fff;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
  border: 1px solid #e0e0e0;
  color: #333;
}

.form-textarea {
  background: #fff;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
  border: 1px solid #e0e0e0;
  min-height: 80px;
  color: #333;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.image-item,
.image-add {
  aspect-ratio: 1 / 1;
  border-radius: 8px;
}

.image-item {
  position: relative;
  overflow: hidden;
  background: #fff;
  border: 1px solid #e0e0e0;
}

.image-thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.image-remove {
  position: absolute;
  right: 6px;
  bottom: 6px;
  margin: 0;
  min-width: 0;
  padding: 0 10px;
  height: 24px;
  line-height: 24px;
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.58);
  color: #fff;
  font-size: 12px;
}

.image-add {
  margin: 0;
  border: 1px dashed #b8c4bd;
  background: #fff;
  color: #00573D;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-hint {
  margin-top: 8px;
  font-size: 12px;
  color: #777;
}

.submit-btn {
  background: #00573D;
  color: #fff;
  border-radius: 24px;
  font-size: 16px;
  margin-top: 24px;
  font-weight: 500;
}

.location-panel {
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
}

.location-summary {
  font-size: 13px;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10px;
}

.location-summary.muted {
  color: #777;
}

.location-name {
  font-weight: 600;
}

.location-coords {
  color: #777;
  font-size: 12px;
  margin-top: 2px;
}

.location-actions {
  display: flex;
  gap: 8px;
}

.location-btn {
  background: #00573D;
  color: #fff;
  border-radius: 16px;
  margin: 0;
}

.location-clear {
  background: #f4f4f4;
  color: #555;
  border-radius: 16px;
  margin: 0;
}
