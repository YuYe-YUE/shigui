.container { min-height: 100vh; background: var(--bg-color); padding: 20rpx; }
.list { column-count: 2; column-gap: 20rpx; }
.list post-card { display: block; break-inside: avoid; margin-bottom: 20rpx; }
.empty { text-align: center; color: var(--text-light); padding: 160rpx 0; font-size: 28rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; opacity: 0.8; }
