.container {
  background: var(--bg-color);
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header-section {
  position: relative;
  padding: 40rpx 30rpx 0;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, rgba(46, 125, 50, 0) 100%);
  z-index: 0;
}

.user-card {
  position: relative;
  z-index: 1;
  background: var(--white);
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(46, 125, 50, 0.08);
  margin-bottom: 40rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light), #e8f5e9);
  padding: 6rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--primary-color);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.tag {
  font-size: 22rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  align-self: flex-start;
}

.login-action {
  margin-left: 20rpx;
}

.btn-login-small {
  background: var(--primary-color);
  color: var(--white);
  font-size: 26rpx;
  padding: 12rpx 36rpx;
  border-radius: 40rpx;
  font-weight: 600;
  margin: 0;
  line-height: 1.5;
  box-shadow: 0 8rpx 16rpx rgba(46, 125, 50, 0.2);
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background: var(--white);
  border-radius: 32rpx;
  padding: 40rpx 20rpx;
  margin: 0 30rpx 40rpx;
  position: relative;
  z-index: 1;
  box-shadow: var(--shadow);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  position: relative;
  transition: opacity 0.2s;
}

.action-item:active {
  opacity: 0.6;
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
}

.action-item text {
  font-size: 26rpx;
  color: var(--text-second);
  font-weight: 500;
}

.menu-group {
  background: var(--white);
  border-radius: 32rpx;
  margin: 0 30rpx 30rpx;
  padding: 10rpx 30rpx;
  box-shadow: var(--shadow);
  position: relative;
  z-index: 1;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: opacity 0.2s;
}

.menu-item:active {
  opacity: 0.6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 500;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

.badge {
  width: 16rpx;
  height: 16rpx;
  background: #FF5252;
  border-radius: 50%;
  margin-right: 16rpx;
}
