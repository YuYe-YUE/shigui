<view class="container">
  <view class="form-group">
    <view class="form-label">物品名称 <text class="required">*</text></view>
    <input class="form-input" placeholder="如：校园卡、黑色双肩包" data-field="itemName" bindinput="setField" value="{{form.itemName}}" />
  </view>

  <view class="form-group">
    <view class="form-label">物品类别 <text class="required">*</text></view>
    <picker mode="selector" range="{{categories}}" bindchange="selectCategory">
      <view class="form-input">{{form.itemCategory || '请选择'}}</view>
    </picker>
  </view>

  <view class="form-group">
    <view class="form-label">时间 <text class="required">*</text></view>
    <picker mode="date" data-field="eventTime" bindchange="setField">
      <view class="form-input">{{form.eventTime || '请选择'}}</view>
    </picker>
  </view>

  <view class="form-group">
    <view class="form-label">校园区域</view>
    <input class="form-input" placeholder="如：南校区" data-field="campusArea" bindinput="setField" value="{{form.campusArea}}" />
  </view>

  <view class="form-group">
    <view class="form-label">具体地点 <text class="required">*</text></view>
    <input class="form-input" placeholder="如：第二食堂二楼" data-field="locationName" bindinput="setField" value="{{form.locationName}}" />
  </view>

  <view class="form-group">
    <view class="form-label">物品描述</view>
    <textarea class="form-textarea" placeholder="补充物品的外观、颜色、品牌等特征" data-field="description" bindinput="setField" value="{{form.description}}" />
  </view>

  <view class="form-group">
    <view class="form-label">非公开特征</view>
    <textarea class="form-textarea" placeholder="只有真正的物主才知道的信息，用于核验身份" data-field="privateFeature" bindinput="setField" value="{{form.privateFeature}}" />
  </view>

  <view class="form-group" wx:if="{{postType === 'FOUND'}}">
    <view class="form-label">暂存地点</view>
    <input class="form-input" placeholder="物品现在存放在哪里" data-field="storageLocation" bindinput="setField" value="{{form.storageLocation}}" />
  </view>

  <button class="submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">提交发布</button>
</view>
