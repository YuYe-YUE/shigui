.container { min-height: 100vh; background: var(--bg-color); padding: 24rpx; }
.match-card { background: var(--white); border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: var(--shadow); }
.score-badge { display: inline-block; background: var(--primary-light); color: var(--primary-color); font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; font-weight: 600; margin-bottom: 16rpx; }
.reason { font-size: 26rpx; color: var(--text-second); margin-bottom: 20rpx; line-height: 1.6; }
.posts { display: flex; flex-direction: column; gap: 12rpx; }
.post-item { padding: 16rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 26rpx; }
.label { color: var(--primary-color); font-weight: 600; margin-right: 12rpx; }
.empty { text-align: center; color: var(--text-light); padding: 160rpx 0; font-size: 28rpx; }
