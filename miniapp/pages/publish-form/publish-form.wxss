.container { padding: 14px; }

.form-group { margin-bottom: 16px; }
.form-label { font-size: 14px; font-weight: 600; margin-bottom: 6px; color: #333; }
.required { color: #e74c3c; }

.form-input {
  background: #fff;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
  border: 1px solid #e0e0e0;
  color: #333;
}

.form-textarea {
  background: #fff;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
  border: 1px solid #e0e0e0;
  min-height: 80px;
  color: #333;
}

.submit-btn {
  background: #00573D;
  color: #fff;
  border-radius: 24px;
  font-size: 16px;
  margin-top: 24px;
  font-weight: 500;
}
